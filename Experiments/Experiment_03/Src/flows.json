                "p": "topic",
                "vt": "str"
            }
        ],
        "repeat": "",
        "crontab": "",
        "once": true,
        "onceDelay": 0.1,
        "topic": "CREATE TABLE IF NOT EXISTS sensor_data(id INTEGER PRIMARY KEY AUTOINCREMENT, timestamp INTEGER NOT NULL, gateway_id TEXT NOT NULL, device_id TEXT NOT NULL, value REAL NOT NULL)",
        "x": 510,
        "y": 740,
