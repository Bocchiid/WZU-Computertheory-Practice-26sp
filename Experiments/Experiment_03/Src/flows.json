        "name": "function 15",
        "func": "var gatewayId = context.flow.get(\"gatewayId\");\nvar deviceId = context.flow.get(\"deviceId\");\nvar startTime = context.flow.get(\"startTime\");\nvar endTime = context.flow.get(\"endTime\");\n// 确保所有参数都存在\nif (!gatewayId || !deviceId || !startTime || !endTime) {\n    msg.error = '缺少必要参数';\n    msg.params = {\n        gatewayId: gatewayId,\n        deviceId: deviceId,\n        startTime: startTime,\n        endTime: endTime\n    };\n    return msg;\n}\n// 生成 SQL 语句\nmsg.topic = `\n        SELECT timestamp, value\n        FROM sensor_data\n        WHERE gateway_id = '${gatewayId}'\n            AND device_id = '${deviceId}'\n            AND timestamp >= ${startTime}\n            AND timestamp <= ${endTime}\n        ORDER BY timestamp ASC\n`;\nreturn msg;",
