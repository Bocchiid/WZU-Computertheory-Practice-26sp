    {
        "id": "c167ece3aac971a6",
        "type": "function",
        "z": "9f8f6a74d0434b79",
        "name": "function 8",
        "func": "// 1. 解析 topic, 提取 gateway_id 和 device_id\nlet topicParts = msg.topic.split('/');\nlet gatewayId = topicParts[1];\nlet deviceId = topicParts[2];\n// 2. 提取数值 (支持 number, boolean, 对象)\nlet rawValue = null;\nif (msg.payload !== undefined && msg.payload !== null) {\n    if (typeof msg.payload === 'number') {\n        rawValue = msg.payload;\n    }\n    else if (typeof msg.payload === 'boolean') {\n        rawValue = msg.payload ? 1 : 0;\n    }\n    else if (typeof msg.payload === 'object') {\n        // 取对象的第一个数值 (忽略键名)\n        let values = Object.values(msg.payload);\n        if (values.length > 0) {\n            let firstVal = values[0];\n            if (typeof firstVal === 'number') {\n                rawValue = firstVal;\n            } else if (typeof firstVal === 'boolean') {\n                rawValue = firstVal ? 1 : 0;\n            }\n        }\n    }\n}\n// 3. 校验字段完整性\nif (!gatewayId || !deviceId) {\n    node.warn(`Missing gatewayId or deviceId in topic: ${msg.topic}`);\n    return null;\n}\nif (rawValue === null || isNaN(rawValue)) {\n    node.warn(`Invalid value in payload: ${JSON.stringify(msg.payload)}`);\n    return null;\n}\n// 4. 构造 SQL INSERT 语句\nlet timestamp = Date.now();\nlet sql = `INSERT INTO sensor_data (timestamp, gateway_id, device_id, value) VALUES (${timestamp}, '${gatewayId}', '${deviceId}', ${rawValue})`;\nmsg.topic = sql;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 500,
        "y": 660,
        "wires": [
            [
                "6c5ec6b317bdf03c"
            ]
        ]
    },
